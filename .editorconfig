# top-most EditorConfig file
root = true

#-------------------------------------------------
# file format
#-------------------------------------------------
[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

[*.{sln,slnx,csproj,props,targets}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2
